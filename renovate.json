{
  "extends": ["config:recommended", ":semanticCommits"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "assignees": ["@renovate", "@neureka"],
      "labels": ["Type/Dependency"],
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "assignees": ["@renovate", "@neureka"],
    "labels": ["Type/Dependency", "Type/Security"],
    "automerge": true
  },
  "osvVulnerabilityAlerts": true
}
